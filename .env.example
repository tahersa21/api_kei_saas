# ─────────────────────────────────────────────────────────────────
# CommandCode Chatbot — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# CommandCode API key (from commandcode.ai)
COMMANDCODE_API_KEY=your_commandcode_api_key_here

# Secret for signing admin JWT sessions (generate with: openssl rand -hex 32)
SESSION_SECRET=change_this_to_a_random_secret_string

# Password to access the /dashboard admin panel
ADMIN_PASSWORD=change_this_strong_password

# PostgreSQL connection string
# Local:      postgresql://user:password@localhost:5432/dbname
# Cloud SQL:  postgresql://user:password@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://user:password@localhost:5432/commandcode

# Port the server listens on (Cloud Run sets this automatically)
PORT=8080
