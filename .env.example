# ─────────────────────────────────────────────────────────────────────────────
# CommandCode — Environment Variables Template
# Copy this file to .env and fill in all values before deploying.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
LOG_LEVEL=info

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Local:      postgresql://commandcode:pass@localhost:5432/commandcode
# Cloud SQL:  postgresql://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://commandcode:CHANGE_ME@localhost:5432/commandcode

# Used only by docker-compose (password part of DATABASE_URL above)
POSTGRES_PASSWORD=CHANGE_ME

# ── Admin ─────────────────────────────────────────────────────────────────────
# Password for /dashboard and /taherlt admin pages
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Random secret for Express session signing (generate: openssl rand -hex 32)
SESSION_SECRET=CHANGE_ME_64_CHAR_HEX

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY=pk_live_XXXX
CLERK_SECRET_KEY=sk_live_XXXX

# ── Upstream AI Provider Keys (optional — managed via Admin UI) ────────────────
# Fallback CommandCode key if no keys are configured in the DB pool
COMMANDCODE_API_KEY=

# ── VPS / Docker Compose only ─────────────────────────────────────────────────
# Port exposed on the host machine (default 80 → maps to container's 8080)
HOST_PORT=80
